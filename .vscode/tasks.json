{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build Thief",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"group": "build",
			"isBackground": false,
			"problemMatcher": [
				"$eslint-stylish"
			]
		},
		{
			"label": "Start Thief Dev",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev"
			],
			"group": "build",
			"isBackground": true,
			"problemMatcher": [
				"$eslint-stylish"
			]
		}
	]
}
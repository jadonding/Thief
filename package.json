{
  "name": "thief",
  "version": "4.0.0",
  "author": "SanJin <lauixData@gamil.com>",
  "description": "一款真正的创新摸鱼神器",
  "license": "MIT",
  "main": "./dist/electron/main.js",
  "scripts": {
    "build": "node .electron-vue/build.js && electron-builder",
    "build:win64": "node .electron-vue/build.js && electron-builder --win --x64",
    "build:win32": "node .electron-vue/build.js && electron-builder --win --ia32",
    "build:linux64": "node .electron-vue/build.js && electron-builder --linux --x64",
    "build:linux32": "node .electron-vue/build.js && electron-builder --linux --ia32",
    "build:mac": "node .electron-vue/build.js && electron-builder --mac --x64",
    "build:all": "node .electron-vue/build.js && electron-builder --platform=all",
    "build:dir": "node .electron-vue/build.js && electron-builder --dir",
    "build:clean": "cross-env BUILD_TARGET=clean node .electron-vue/build.js",
    "build:web": "cross-env BUILD_TARGET=web node .electron-vue/build.js",
    "dev": "node .electron-vue/dev-runner.js",
    "pack": "npm run pack:main && npm run pack:renderer",
    "pack:main": "cross-env NODE_ENV=production webpack --progress --colors --config .electron-vue/webpack.main.config.js",
    "pack:renderer": "cross-env NODE_ENV=production webpack --progress --colors --config .electron-vue/webpack.renderer.config.js",
    "postinstall": ""
  },
  "build": {
    "productName": "thief",
    "appId": "c.team.thief",
    "directories": {
      "output": "build"
    },
    "files": [
      "dist/electron/**/*"
    ],
    "dmg": {
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    },
    "mac": {
      "icon": "build/icons/icon.icns"
    },
    "win": {
      "icon": "static/icon.png"
    },
    "linux": {
      "icon": "build/icons"
    }
  },
  "dependencies": {
    "@electron/remote": "^2.1.2",
    "axios": "^1.13.6",
    "element-ui": "^2.15.14",
    "encoding_convertor": "^0.2.1",
    "fast-gbk": "^0.0.1",
    "fs-extra": "^11.3.4",
    "hotkeys-js": "^4.0.2",
    "iconv-lite": "^0.7.2",
    "pdfjs-dist": "^2.16.105",
    "superagent": "^10.3.0",
    "superagent-charset": "^1.2.0",
    "vue": "^2.7.16",
    "vue-electron": "^1.0.6",
    "vue-router": "^3.6.5",
    "vuex": "^3.6.2",
    "vuex-electron": "^1.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "ajv": "^6.14.0",
    "babel-loader": "^8.4.1",
    "cfonts": "^2.10.1",
    "chalk": "^2.4.2",
    "copy-webpack-plugin": "^4.6.0",
    "cross-env": "^5.2.1",
    "css-loader": "^0.28.11",
    "del": "^3.0.0",
    "devtron": "^1.4.0",
    "electron": "^28.3.3",
    "electron-builder": "^26.0.12",
    "electron-debug": "^1.5.0",
    "electron-devtools-installer": "^2.2.4",
    "file-loader": "^1.1.11",
    "html-webpack-plugin": "^3.2.0",
    "mini-css-extract-plugin": "0.12.0",
    "multispinner": "^0.2.1",
    "node-loader": "^0.6.0",
    "sass": "^1.90.0",
    "sass-loader": "^7.3.1",
    "style-loader": "^0.23.1",
    "url-loader": "^1.1.2",
    "vue-html-loader": "^1.2.4",
    "vue-loader": "^15.11.1",
    "vue-style-loader": "^4.1.3",
    "vue-template-compiler": "^2.7.16",
    "webpack": "^4.47.0",
    "webpack-cli": "^3.3.12",
    "webpack-dev-server": "^3.11.3",
    "webpack-hot-middleware": "^2.26.1",
    "webpack-merge": "^4.2.2"
  }
}
